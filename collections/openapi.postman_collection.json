                  "key": "category",
                  "value": "<string>",
                  "description": "Filter by font category."
                },
                {
                  "disabled": false,
                  "key": "capability",
                  "value": "<string>",
                  "description": "Request additional capabilities like WOFF2, variable fonts (VF), or family tags."
